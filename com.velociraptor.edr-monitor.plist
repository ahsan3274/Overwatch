<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  EDR Database Monitor for Overwatch
  
  Install:   cp com.velociraptor.edr-monitor.plist ~/Library/LaunchAgents/
             launchctl load ~/Library/LaunchAgents/com.velociraptor.edr-monitor.plist
  Uninstall: launchctl unload ~/Library/LaunchAgents/com.velociraptor.edr-monitor.plist
             rm ~/Library/LaunchAgents/com.velociraptor.edr-monitor.plist
  
  Monitors EDR integration for:
  - SQLite database corruption
  - Hash lookup API failures
  - YARA scanning errors
  - Database lock issues
  - Cache performance
-->
<plist version="1.0">
<dict>

    <key>Label</key>
    <string>com.velociraptor.edr-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/YOUR_USERNAME/velociraptor-triage/edr_monitor.py</string>
        <string>--watch</string>
        <string>--interval</string>
        <string>300</string>
    </array>

    <!-- Check every 5 minutes -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/Users/YOUR_USERNAME/velociraptor-triage/edr_monitor_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USERNAME/velociraptor-triage/edr_monitor_stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/YOUR_USERNAME/.lmstudio/bin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>

    <key>KeepAlive</key>
    <false/>

    <key>RunAtLoad</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>

</dict>
</plist>
